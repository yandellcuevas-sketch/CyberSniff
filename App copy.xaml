<Application x:Class="CyberSniff.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="MainWindow.xaml">

    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>

                <!-- 1. MaterialDesignThemes base (Dark) -->
                <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesignTheme.Dark.xaml"/>
                <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesignTheme.Defaults.xaml"/>

                <!-- 2. Tema propio de CyberSniff  ← sobreescribe Material -->
                <ResourceDictionary Source="/CyberSniff.Themes/CyberSniffTheme.xaml"/>

                <!--
                    Para cambiar a un tema alternativo (ej. tema morado) solo
                    cambia la línea anterior por:
                    <ResourceDictionary Source="/CyberSniff.Themes/CyberSniffTheme.Purple.xaml"/>

                    O en runtime desde código:
                    App.Current.Resources.MergedDictionaries[2] =
                        new ResourceDictionary { Source = new Uri("...Purple.xaml", UriKind.Relative) };
                -->
            </ResourceDictionary.MergedDictionaries>

            <!-- Estilo global de texto para toda la app -->
            <Style TargetType="TextBlock" BasedOn="{StaticResource TextPrimary}"/>

            <!-- Tipografía base de la app -->
            <FontFamily x:Key="{x:Static SystemFonts.MessageFontFamilyKey}">
                Segoe UI Variable Display, Segoe UI
            </FontFamily>

            <!-- Cursor personalizado en toda la app -->
            <Cursor x:Key="HandCursor">Hand</Cursor>
        </ResourceDictionary>
    </Application.Resources>

</Application>
