<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ═══════════════════════════════════════════════════════════════
         CYBERSNIFF DESIGN SYSTEM  —  Paleta de colores dinámica
         Para cambiar el tema completo, solo modifica los valores aquí.
         ═══════════════════════════════════════════════════════════════ -->

    <!-- ── Fondos ────────────────────────────────────────────────── -->
    <Color x:Key="BgPrimaryColor">#FF0A0C10</Color>
    <Color x:Key="BgSurfaceColor">#FF111318</Color>
    <Color x:Key="BgSurface2Color">#FF181B22</Color>
    <Color x:Key="BgSurface3Color">#FF1E2028</Color>
    <Color x:Key="BgHoverColor">#18FFFFFF</Color>
    <Color x:Key="BgActiveColor">#28FFFFFF</Color>

    <!-- ── Acentos ────────────────────────────────────────────────── -->
    <Color x:Key="AccentCyanColor">#FF00E5FF</Color>
    <Color x:Key="AccentCyanDimColor">#1A00E5FF</Color>
    <Color x:Key="AccentPurpleColor">#FF7C3AED</Color>
    <Color x:Key="AccentPurpleDimColor">#1E7C3AED</Color>
    <Color x:Key="AccentGreenColor">#FF10B981</Color>
    <Color x:Key="AccentGreenDimColor">#1A10B981</Color>
    <Color x:Key="AccentAmberColor">#FFF59E0B</Color>
    <Color x:Key="AccentAmberDimColor">#1AF59E0B</Color>
    <Color x:Key="AccentRedColor">#FFEF4444</Color>
    <Color x:Key="AccentRedDimColor">#1AEF4444</Color>

    <!-- ── Texto ─────────────────────────────────────────────────── -->
    <Color x:Key="TextPrimaryColor">#FFE2E8F0</Color>
    <Color x:Key="TextSecondaryColor">#FF8892A4</Color>
    <Color x:Key="TextTertiaryColor">#FF4A5568</Color>

    <!-- ── Bordes ─────────────────────────────────────────────────── -->
    <Color x:Key="BorderSubtleColor">#12FFFFFF</Color>
    <Color x:Key="BorderNormalColor">#1EFFFFFF</Color>
    <Color x:Key="BorderStrongColor">#30FFFFFF</Color>

    <!-- Brushes desde los colores ─────────────────────────────────── -->
    <SolidColorBrush x:Key="BgPrimaryBrush"      Color="{DynamicResource BgPrimaryColor}"/>
    <SolidColorBrush x:Key="BgSurfaceBrush"      Color="{DynamicResource BgSurfaceColor}"/>
    <SolidColorBrush x:Key="BgSurface2Brush"     Color="{DynamicResource BgSurface2Color}"/>
    <SolidColorBrush x:Key="BgSurface3Brush"     Color="{DynamicResource BgSurface3Color}"/>
    <SolidColorBrush x:Key="BgHoverBrush"        Color="{DynamicResource BgHoverColor}"/>
    <SolidColorBrush x:Key="BgActiveBrush"       Color="{DynamicResource BgActiveColor}"/>

    <SolidColorBrush x:Key="AccentCyanBrush"     Color="{DynamicResource AccentCyanColor}"/>
    <SolidColorBrush x:Key="AccentCyanDimBrush"  Color="{DynamicResource AccentCyanDimColor}"/>
    <SolidColorBrush x:Key="AccentPurpleBrush"   Color="{DynamicResource AccentPurpleColor}"/>
    <SolidColorBrush x:Key="AccentGreenBrush"    Color="{DynamicResource AccentGreenColor}"/>
    <SolidColorBrush x:Key="AccentAmberBrush"    Color="{DynamicResource AccentAmberColor}"/>
    <SolidColorBrush x:Key="AccentRedBrush"      Color="{DynamicResource AccentRedColor}"/>
    <SolidColorBrush x:Key="AccentRedDimBrush"   Color="{DynamicResource AccentRedDimColor}"/>

    <SolidColorBrush x:Key="TextPrimaryBrush"    Color="{DynamicResource TextPrimaryColor}"/>
    <SolidColorBrush x:Key="TextSecondaryBrush"  Color="{DynamicResource TextSecondaryColor}"/>
    <SolidColorBrush x:Key="TextTertiaryBrush"   Color="{DynamicResource TextTertiaryColor}"/>

    <SolidColorBrush x:Key="BorderSubtleBrush"   Color="{DynamicResource BorderSubtleColor}"/>
    <SolidColorBrush x:Key="BorderNormalBrush"   Color="{DynamicResource BorderNormalColor}"/>
    <SolidColorBrush x:Key="BorderStrongBrush"   Color="{DynamicResource BorderStrongColor}"/>

    <!-- Transparente reutilizable -->
    <SolidColorBrush x:Key="TransparentBrush" Color="Transparent"/>

    <!-- ═══════════════════════════════════════════════════════════════
         TIPOGRAFÍA
         ═══════════════════════════════════════════════════════════════ -->
    <FontFamily x:Key="MonoFont">Cascadia Code, Consolas, Courier New</FontFamily>
    <FontFamily x:Key="UiFont">Segoe UI Variable Display, Segoe UI, Arial</FontFamily>

    <!-- ═══════════════════════════════════════════════════════════════
         ESTILOS DE TEXTO
         ═══════════════════════════════════════════════════════════════ -->
    <Style x:Key="TextPrimary" TargetType="TextBlock">
        <Setter Property="FontFamily"   Value="{DynamicResource UiFont}"/>
        <Setter Property="Foreground"   Value="{DynamicResource TextPrimaryBrush}"/>
        <Setter Property="FontSize"     Value="12"/>
    </Style>

    <Style x:Key="TextSecondary" TargetType="TextBlock"
           BasedOn="{StaticResource TextPrimary}">
        <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
        <Setter Property="FontSize"   Value="11"/>
    </Style>

    <Style x:Key="TextMono" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{DynamicResource MonoFont}"/>
        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
        <Setter Property="FontSize"   Value="11"/>
    </Style>

    <Style x:Key="LabelCaps" TargetType="TextBlock">
        <Setter Property="FontFamily"       Value="{DynamicResource UiFont}"/>
        <Setter Property="Foreground"       Value="{DynamicResource TextTertiaryBrush}"/>
        <Setter Property="FontSize"         Value="9"/>
        <Setter Property="FontWeight"       Value="Medium"/>
        <Setter Property="TextOptions.TextFormattingMode" Value="Display"/>
    </Style>

    <!-- ═══════════════════════════════════════════════════════════════
         BADGE DE PROTOCOLO  (TCP / UDP / HTTP / DNS / TLS)
         Uso:  <ContentControl Style="{DynamicResource ProtoBadge_TCP}" Content="TCP"/>
         ═══════════════════════════════════════════════════════════════ -->
    <Style x:Key="ProtoBadgeBase" TargetType="Border">
        <Setter Property="CornerRadius"    Value="3"/>
        <Setter Property="Padding"         Value="7,2"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <Style x:Key="ProtoBadge_TCP" TargetType="Border"
           BasedOn="{StaticResource ProtoBadgeBase}">
        <Setter Property="Background" Value="{DynamicResource AccentCyanDimBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource AccentCyanBrush}"/>
        <Setter Property="BorderThickness" Value="0.5"/>
    </Style>
    <Style x:Key="ProtoBadge_UDP" TargetType="Border"
           BasedOn="{StaticResource ProtoBadgeBase}">
        <Setter Property="Background">
            <Setter.Value><SolidColorBrush Color="#1E7C3AED"/></Setter.Value>
        </Setter>
        <Setter Property="BorderBrush" Value="{DynamicResource AccentPurpleBrush}"/>
        <Setter Property="BorderThickness" Value="0.5"/>
    </Style>
    <Style x:Key="ProtoBadge_HTTP" TargetType="Border"
           BasedOn="{StaticResource ProtoBadgeBase}">
        <Setter Property="Background" Value="{DynamicResource AccentGreenDimBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource AccentGreenBrush}"/>
        <Setter Property="BorderThickness" Value="0.5"/>
    </Style>
    <Style x:Key="ProtoBadge_DNS" TargetType="Border"
           BasedOn="{StaticResource ProtoBadgeBase}">
        <Setter Property="Background">
            <Setter.Value><SolidColorBrush Color="#1AF59E0B"/></Setter.Value>
        </Setter>
        <Setter Property="BorderBrush" Value="{DynamicResource AccentAmberBrush}"/>
        <Setter Property="BorderThickness" Value="0.5"/>
    </Style>
    <Style x:Key="ProtoBadge_TLS" TargetType="Border"
           BasedOn="{StaticResource ProtoBadgeBase}">
        <Setter Property="Background" Value="{DynamicResource AccentRedDimBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource AccentRedBrush}"/>
        <Setter Property="BorderThickness" Value="0.5"/>
    </Style>

    <!-- ═══════════════════════════════════════════════════════════════
         BOTÓN  —  Variante Ghost (borde sutil, hover con fondo)
         ═══════════════════════════════════════════════════════════════ -->
    <Style x:Key="BtnGhost" TargetType="Button">
        <Setter Property="Background"   Value="Transparent"/>
        <Setter Property="BorderBrush"  Value="{DynamicResource BorderNormalBrush}"/>
        <Setter Property="BorderThickness" Value="0.5"/>
        <Setter Property="Foreground"   Value="{DynamicResource TextSecondaryBrush}"/>
        <Setter Property="FontFamily"   Value="{DynamicResource UiFont}"/>
        <Setter Property="FontSize"     Value="11"/>
        <Setter Property="FontWeight"   Value="Medium"/>
        <Setter Property="Padding"      Value="12,6"/>
        <Setter Property="Cursor"       Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="RootBorder"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="6"
                            Padding="{TemplateBinding Padding}"
                            RenderTransformOrigin="0.5,0.5">
                        <Border.RenderTransform>
                            <ScaleTransform x:Name="Scale" ScaleX="1" ScaleY="1"/>
                        </Border.RenderTransform>
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          RecognizesAccessKey="True"/>
                        <VisualStateManager.VisualStateGroups>
                            <VisualStateGroup x:Name="CommonStates">
                                <VisualStateGroup.Transitions>
                                    <VisualTransition GeneratedDuration="0:0:0.15"/>
                                </VisualStateGroup.Transitions>
                                <VisualState x:Name="Normal"/>
                                <VisualState x:Name="MouseOver">
                                    <Storyboard>
                                        <ColorAnimation
                                            Storyboard.TargetName="RootBorder"
                                            Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                            To="{DynamicResource BgHoverColor}"
                                            Duration="0:0:0.15"/>
                                        <ColorAnimation
                                            Storyboard.TargetName="RootBorder"
                                            Storyboard.TargetProperty="(Border.BorderBrush).(SolidColorBrush.Color)"
                                            To="{DynamicResource BorderStrongColor}"
                                            Duration="0:0:0.15"/>
                                    </Storyboard>
                                </VisualState>
                                <VisualState x:Name="Pressed">
                                    <Storyboard>
                                        <DoubleAnimation
                                            Storyboard.TargetName="Scale"
                                            Storyboard.TargetProperty="ScaleX"
                                            To="0.97" Duration="0:0:0.08"/>
                                        <DoubleAnimation
                                            Storyboard.TargetName="Scale"
                                            Storyboard.TargetProperty="ScaleY"
                                            To="0.97" Duration="0:0:0.08"/>
                                        <ColorAnimation
                                            Storyboard.TargetName="RootBorder"
                                            Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                            To="{DynamicResource BgActiveColor}"
                                            Duration="0:0:0.08"/>
                                    </Storyboard>
                                </VisualState>
                                <VisualState x:Name="Disabled">
                                    <Storyboard>
                                        <DoubleAnimation
                                            Storyboard.TargetName="RootBorder"
                                            Storyboard.TargetProperty="Opacity"
                                            To="0.35" Duration="0:0:0"/>
                                    </Storyboard>
                                </VisualState>
                            </VisualStateGroup>
                        </VisualStateManager.VisualStateGroups>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ── Botón Primary (cyan sólido) ────────────────────────────── -->
    <Style x:Key="BtnPrimary" TargetType="Button"
           BasedOn="{StaticResource BtnGhost}">
        <Setter Property="Background"   Value="{DynamicResource AccentCyanBrush}"/>
        <Setter Property="BorderBrush"  Value="{DynamicResource AccentCyanBrush}"/>
        <Setter Property="Foreground">
            <Setter.Value><SolidColorBrush Color="#FF000000"/></Setter.Value>
        </Setter>
        <Setter Property="FontWeight" Value="SemiBold"/>
    </Style>

    <!-- ── Botón Danger (rojo, para Detener captura) ──────────────── -->
    <Style x:Key="BtnDanger" TargetType="Button"
           BasedOn="{StaticResource BtnGhost}">
        <Setter Property="Background"  Value="{DynamicResource AccentRedDimBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource AccentRedBrush}"/>
        <Setter Property="Foreground"  Value="{DynamicResource AccentRedBrush}"/>
        <Setter Property="FontWeight"  Value="SemiBold"/>
    </Style>

    <!-- ═══════════════════════════════════════════════════════════════
         ITEM DE NAVEGACIÓN  (sidebar)
         ═══════════════════════════════════════════════════════════════ -->
    <Style x:Key="NavItem" TargetType="ListBoxItem">
        <Setter Property="Background"      Value="Transparent"/>
        <Setter Property="Foreground"      Value="{DynamicResource TextSecondaryBrush}"/>
        <Setter Property="Padding"         Value="10,8"/>
        <Setter Property="Margin"          Value="6,1"/>
        <Setter Property="Cursor"          Value="Hand"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ListBoxItem">
                    <Grid>
                        <!-- Indicador lateral activo -->
                        <Rectangle x:Name="ActiveBar"
                                   Width="2" HorizontalAlignment="Left"
                                   RadiusX="1" RadiusY="1"
                                   Fill="{DynamicResource AccentCyanBrush}"
                                   Opacity="0"/>
                        <Border x:Name="RootBorder"
                                Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <VisualStateManager.VisualStateGroups>
                            <VisualStateGroup x:Name="CommonStates">
                                <VisualStateGroup.Transitions>
                                    <VisualTransition GeneratedDuration="0:0:0.15"/>
                                </VisualStateGroup.Transitions>
                                <VisualState x:Name="Normal"/>
                                <VisualState x:Name="MouseOver">
                                    <Storyboard>
                                        <ColorAnimation
                                            Storyboard.TargetName="RootBorder"
                                            Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                            To="{DynamicResource BgHoverColor}"
                                            Duration="0:0:0.15"/>
                                    </Storyboard>
                                </VisualState>
                                <VisualState x:Name="Selected">
                                    <Storyboard>
                                        <ColorAnimation
                                            Storyboard.TargetName="RootBorder"
                                            Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                            To="{DynamicResource AccentCyanDimColor}"
                                            Duration="0:0:0.2"/>
                                        <DoubleAnimation
                                            Storyboard.TargetName="ActiveBar"
                                            Storyboard.TargetProperty="Opacity"
                                            To="1" Duration="0:0:0.2"/>
                                    </Storyboard>
                                </VisualState>
                            </VisualStateGroup>
                        </VisualStateManager.VisualStateGroups>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Foreground" Value="{DynamicResource AccentCyanBrush}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- ═══════════════════════════════════════════════════════════════
         DATAGRID  —  Tema oscuro completo
         ═══════════════════════════════════════════════════════════════ -->
    <Style x:Key="PacketGrid" TargetType="DataGrid">
        <Setter Property="Background"            Value="Transparent"/>
        <Setter Property="Foreground"            Value="{DynamicResource TextSecondaryBrush}"/>
        <Setter Property="BorderThickness"       Value="0"/>
        <Setter Property="GridLinesVisibility"   Value="Horizontal"/>
        <Setter Property="HorizontalGridLinesBrush" Value="{DynamicResource BorderSubtleBrush}"/>
        <Setter Property="RowBackground"         Value="Transparent"/>
        <Setter Property="AlternatingRowBackground" Value="Transparent"/>
        <Setter Property="ColumnHeadersHeight"   Value="32"/>
        <Setter Property="RowHeight"             Value="34"/>
        <Setter Property="FontFamily"            Value="{DynamicResource MonoFont}"/>
        <Setter Property="FontSize"              Value="11"/>
        <Setter Property="SelectionMode"         Value="Single"/>
        <Setter Property="AutoGenerateColumns"   Value="False"/>
        <Setter Property="CanUserResizeRows"     Value="False"/>
        <Setter Property="CanUserAddRows"        Value="False"/>
        <Setter Property="EnableRowVirtualization" Value="True"/>
        <Setter Property="VirtualizingPanel.ScrollUnit" Value="Pixel"/>
        <Setter Property="ScrollViewer.CanContentScroll" Value="True"/>
    </Style>

    <!-- Encabezado de columna del DataGrid -->
    <Style x:Key="PacketGridColumnHeader" TargetType="DataGridColumnHeader">
        <Setter Property="Background"   Value="{DynamicResource BgSurfaceBrush}"/>
        <Setter Property="Foreground"   Value="{DynamicResource TextTertiaryBrush}"/>
        <Setter Property="FontFamily"   Value="{DynamicResource UiFont}"/>
        <Setter Property="FontSize"     Value="9"/>
        <Setter Property="FontWeight"   Value="Medium"/>
        <Setter Property="Padding"      Value="12,0"/>
        <Setter Property="Height"       Value="32"/>
        <Setter Property="BorderThickness" Value="0,0,0,0.5"/>
        <Setter Property="BorderBrush"  Value="{DynamicResource BorderNormalBrush}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="DataGridColumnHeader">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            Padding="{TemplateBinding Padding}">
                        <TextBlock Text="{TemplateBinding Content}"
                                   VerticalAlignment="Center"
                                   TextTransform="Uppercase"
                                   LetterSpacing="0.08em"
                                   Foreground="{TemplateBinding Foreground}"
                                   FontSize="{TemplateBinding FontSize}"
                                   FontWeight="{TemplateBinding FontWeight}"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Fila del DataGrid -->
    <Style x:Key="PacketGridRow" TargetType="DataGridRow">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="DataGridRow">
                    <Border x:Name="RowBorder"
                            Background="{TemplateBinding Background}"
                            BorderThickness="0">
                        <SelectiveScrollingGrid>
                            <SelectiveScrollingGrid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </SelectiveScrollingGrid.ColumnDefinitions>
                            <DataGridCellsPresenter Grid.Column="1"
                                                    ItemsPanel="{TemplateBinding ItemsPanel}"
                                                    SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"/>
                        </SelectiveScrollingGrid>
                        <VisualStateManager.VisualStateGroups>
                            <VisualStateGroup x:Name="CommonStates">
                                <VisualStateGroup.Transitions>
                                    <VisualTransition GeneratedDuration="0:0:0.12"/>
                                </VisualStateGroup.Transitions>
                                <VisualState x:Name="Normal"/>
                                <VisualState x:Name="MouseOver">
                                    <Storyboard>
                                        <ColorAnimation
                                            Storyboard.TargetName="RowBorder"
                                            Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                            To="{DynamicResource BgHoverColor}"
                                            Duration="0:0:0.12"/>
                                    </Storyboard>
                                </VisualState>
                                <VisualState x:Name="Normal_Selected">
                                    <Storyboard>
                                        <ColorAnimation
                                            Storyboard.TargetName="RowBorder"
                                            Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                            To="{DynamicResource AccentCyanDimColor}"
                                            Duration="0:0:0.15"/>
                                    </Storyboard>
                                </VisualState>
                            </VisualStateGroup>
                        </VisualStateManager.VisualStateGroups>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Celda del DataGrid -->
    <Style x:Key="PacketGridCell" TargetType="DataGridCell">
        <Setter Property="Background"   Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Foreground"   Value="{DynamicResource TextSecondaryBrush}"/>
        <Setter Property="Padding"      Value="12,0"/>
        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        <Style.Triggers>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background"  Value="Transparent"/>
                <Setter Property="Foreground"  Value="{DynamicResource TextPrimaryBrush}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- ═══════════════════════════════════════════════════════════════
         SCROLLBAR  —  Minimalista oscura
         ═══════════════════════════════════════════════════════════════ -->
    <Style x:Key="FlatScrollBar" TargetType="ScrollBar">
        <Setter Property="Width"      Value="4"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ScrollBar">
                    <Grid>
                        <Track x:Name="PART_Track" IsDirectionReversed="True">
                            <Track.Thumb>
                                <Thumb>
                                    <Thumb.Template>
                                        <ControlTemplate TargetType="Thumb">
                                            <Border CornerRadius="2"
                                                    Background="{DynamicResource BorderStrongBrush}"
                                                    Opacity="0.5"/>
                                        </ControlTemplate>
                                    </Thumb.Template>
                                </Thumb>
                            </Track.Thumb>
                        </Track>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ═══════════════════════════════════════════════════════════════
         TEXTBOX  —  Buscador / Filtros
         ═══════════════════════════════════════════════════════════════ -->
    <Style x:Key="SearchBox" TargetType="TextBox">
        <Setter Property="Background"     Value="{DynamicResource BgSurface2Brush}"/>
        <Setter Property="Foreground"     Value="{DynamicResource TextPrimaryBrush}"/>
        <Setter Property="FontFamily"     Value="{DynamicResource MonoFont}"/>
        <Setter Property="FontSize"       Value="11"/>
        <Setter Property="BorderBrush"    Value="{DynamicResource BorderNormalBrush}"/>
        <Setter Property="BorderThickness" Value="0.5"/>
        <Setter Property="Padding"        Value="8,6"/>
        <Setter Property="CaretBrush"     Value="{DynamicResource AccentCyanBrush}"/>
        <Setter Property="SelectionBrush" Value="{DynamicResource AccentCyanDimBrush}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TextBox">
                    <Border x:Name="RootBorder"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="6"
                            Padding="{TemplateBinding Padding}">
                        <ScrollViewer x:Name="PART_ContentHost"
                                      Focusable="False"
                                      HorizontalScrollBarVisibility="Hidden"
                                      VerticalScrollBarVisibility="Hidden"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsFocused" Value="True">
                            <Setter TargetName="RootBorder"
                                    Property="BorderBrush"
                                    Value="{DynamicResource AccentCyanBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ═══════════════════════════════════════════════════════════════
         SEPARADOR  —  Línea vertical en toolbar
         ═══════════════════════════════════════════════════════════════ -->
    <Style x:Key="ToolbarSep" TargetType="Rectangle">
        <Setter Property="Width"  Value="0.5"/>
        <Setter Property="Fill"   Value="{DynamicResource BorderNormalBrush}"/>
        <Setter Property="Margin" Value="4,6"/>
    </Style>

    <!-- ═══════════════════════════════════════════════════════════════
         CHIP DE ESTADÍSTICA  (barra de resumen)
         ═══════════════════════════════════════════════════════════════ -->
    <Style x:Key="StatChip" TargetType="Border">
        <Setter Property="Padding"          Value="12,6"/>
        <Setter Property="BorderThickness"  Value="0,0,0.5,0"/>
        <Setter Property="BorderBrush"      Value="{DynamicResource BorderSubtleBrush}"/>
    </Style>

</ResourceDictionary>
