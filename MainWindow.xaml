<Window x:Class="CyberSniff.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CyberSniff"
        mc:Ignorable="d"
        Title="CyberSniff"
        Height="720" Width="1280"
        MinHeight="540" MinWidth="900"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="CanResizeWithGrip"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <!-- Importa el diccionario de tema -->
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/CyberSniff.Themes/CyberSniffTheme.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <!-- Conversor para ocultar/mostrar etiquetas según estado del sidebar -->
            <BooleanToVisibilityConverter x:Key="BoolToVis"/>

            <!-- Ancho animable del sidebar (se modifica desde code-behind) -->
            <system:Double xmlns:system="clr-namespace:System;assembly=mscorlib"
                           x:Key="SidebarExpandedWidth">200</system:Double>
            <system:Double xmlns:system="clr-namespace:System;assembly=mscorlib"
                           x:Key="SidebarCollapsedWidth">50</system:Double>
        </ResourceDictionary>
    </Window.Resources>

    <!-- ── Raíz: borde de la ventana con sombra exterior ─────────── -->
    <Border CornerRadius="10"
            Background="{DynamicResource BgPrimaryBrush}"
            BorderBrush="{DynamicResource BorderNormalBrush}"
            BorderThickness="0.5">
        <Border.Effect>
            <DropShadowEffect BlurRadius="40"
                              ShadowDepth="0"
                              Color="#CC000000"
                              Opacity="0.7"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>   <!-- Barra de título -->
                <RowDefinition Height="52"/>   <!-- Toolbar -->
                <RowDefinition Height="30"/>   <!-- Barra de estadísticas -->
                <RowDefinition Height="*"/>    <!-- Área principal -->
                <RowDefinition Height="22"/>   <!-- Status bar -->
            </Grid.RowDefinitions>

            <!-- ══════════════════════════════════════════════════════
                 BARRA DE TÍTULO PERSONALIZADA
                 ══════════════════════════════════════════════════════ -->
            <Border Grid.Row="0"
                    Background="{DynamicResource BgSurfaceBrush}"
                    CornerRadius="10,10,0,0"
                    BorderBrush="{DynamicResource BorderSubtleBrush}"
                    BorderThickness="0,0,0,0.5"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">

                <Grid Margin="12,0,12,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>  <!-- Controles ventana (macOS style) -->
                        <ColumnDefinition Width="Auto"/>  <!-- Logo + nombre -->
                        <ColumnDefinition Width="*"/>     <!-- Spacer -->
                        <ColumnDefinition Width="Auto"/>  <!-- Stats en tiempo real -->
                        <ColumnDefinition Width="Auto"/>  <!-- Controles Windows style -->
                    </Grid.ColumnDefinitions>

                    <!-- Botones macOS-style -->
                    <StackPanel Grid.Column="0"
                                Orientation="Horizontal"
                                VerticalAlignment="Center"
                                Margin="0,0,16,0">
                        <Button x:Name="BtnClose" Width="12" Height="12"
                                Click="BtnClose_Click" Cursor="Hand"
                                Style="{x:Null}" BorderThickness="0"
                                ToolTip="Cerrar">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Ellipse x:Name="Dot" Width="12" Height="12"
                                             Fill="{DynamicResource AccentRedBrush}"/>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <Button Width="12" Height="12"
                                Click="BtnMinimize_Click" Cursor="Hand"
                                Style="{x:Null}" BorderThickness="0"
                                Margin="6,0,0,0" ToolTip="Minimizar">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Ellipse Width="12" Height="12"
                                             Fill="{DynamicResource AccentAmberBrush}"/>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <Button Width="12" Height="12"
                                Click="BtnMaximize_Click" Cursor="Hand"
                                Style="{x:Null}" BorderThickness="0"
                                Margin="6,0,0,0" ToolTip="Maximizar">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Ellipse Width="12" Height="12"
                                             Fill="{DynamicResource AccentGreenBrush}"/>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>

                    <!-- Logo y nombre -->
                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <!-- Punto de acento luminoso -->
                        <Ellipse Width="8" Height="8"
                                 Margin="0,0,8,0"
                                 Fill="{DynamicResource AccentCyanBrush}">
                            <Ellipse.Effect>
                                <DropShadowEffect BlurRadius="6"
                                                  ShadowDepth="0"
                                                  Color="{DynamicResource AccentCyanColor}"
                                                  Opacity="0.8"/>
                            </Ellipse.Effect>
                        </Ellipse>
                        <TextBlock Text="CYBERSNIFF"
                                   FontFamily="{DynamicResource UiFont}"
                                   FontSize="13" FontWeight="Bold"
                                   Foreground="{DynamicResource AccentCyanBrush}"
                                   VerticalAlignment="Center"
                                   CharacterSpacing="100"/>
                        <TextBlock Text=" v2.0"
                                   FontFamily="{DynamicResource MonoFont}"
                                   FontSize="10"
                                   Foreground="{DynamicResource TextTertiaryBrush}"
                                   VerticalAlignment="Center"
                                   Margin="4,0,0,0"/>
                    </StackPanel>

                    <!-- Métricas en tiempo real (barra de título) -->
                    <StackPanel Grid.Column="3"
                                Orientation="Horizontal"
                                VerticalAlignment="Center"
                                Margin="0,0,12,0">
                        <Border Background="{DynamicResource BgSurface2Brush}"
                                BorderBrush="{DynamicResource BorderSubtleBrush}"
                                BorderThickness="0.5" CornerRadius="4"
                                Padding="8,3" Margin="0,0,6,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="IFACE: " Style="{DynamicResource LabelCaps}"/>
                                <TextBlock x:Name="TxtIface" Text="eth0"
                                           FontFamily="{DynamicResource MonoFont}"
                                           FontSize="10"
                                           Foreground="{DynamicResource AccentGreenBrush}"/>
                            </StackPanel>
                        </Border>
                        <Border Background="{DynamicResource BgSurface2Brush}"
                                BorderBrush="{DynamicResource BorderSubtleBrush}"
                                BorderThickness="0.5" CornerRadius="4"
                                Padding="8,3" Margin="0,0,6,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="RX: " Style="{DynamicResource LabelCaps}"/>
                                <TextBlock x:Name="TxtRx" Text="— MB/s"
                                           FontFamily="{DynamicResource MonoFont}"
                                           FontSize="10"
                                           Foreground="{DynamicResource AccentCyanBrush}"/>
                            </StackPanel>
                        </Border>
                        <Border Background="{DynamicResource BgSurface2Brush}"
                                BorderBrush="{DynamicResource BorderSubtleBrush}"
                                BorderThickness="0.5" CornerRadius="4"
                                Padding="8,3">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="PKTS: " Style="{DynamicResource LabelCaps}"/>
                                <TextBlock x:Name="TxtTitlePkts" Text="0"
                                           FontFamily="{DynamicResource MonoFont}"
                                           FontSize="10"
                                           Foreground="{DynamicResource AccentCyanBrush}"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ══════════════════════════════════════════════════════
                 TOOLBAR  (acciones principales)
                 ══════════════════════════════════════════════════════ -->
            <Border Grid.Row="1"
                    Background="{DynamicResource BgSurface2Brush}"
                    BorderBrush="{DynamicResource BorderSubtleBrush}"
                    BorderThickness="0,0,0,0.5">
                <StackPanel Orientation="Horizontal"
                            VerticalAlignment="Center"
                            Margin="16,0">

                    <!-- Botón Capturar / Detener -->
                    <Button x:Name="BtnCaptureToggle"
                            Style="{DynamicResource BtnDanger}"
                            Click="BtnCaptureToggle_Click"
                            Padding="18,9" MinHeight="34" Margin="0,0,10,0">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock x:Name="TxtCaptureIcon"
                                       Text="⏹"
                                       FontSize="13"
                                       VerticalAlignment="Center"
                                       Margin="0,0,8,0"/>
                            <TextBlock x:Name="TxtCaptureLabel"
                                       Text="Detener"
                                       FontFamily="{DynamicResource UiFont}"
                                       FontSize="12" FontWeight="SemiBold"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <!-- Limpiar -->
                    <Button Style="{DynamicResource BtnGhost}"
                            Click="BtnClear_Click"
                            Padding="18,9" MinHeight="34" Margin="0,0,10,0">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="🗑"
                                       FontSize="13"
                                       VerticalAlignment="Center"
                                       Margin="0,0,8,0"/>
                            <TextBlock Text="Limpiar"
                                       FontFamily="{DynamicResource UiFont}"
                                       FontSize="12"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Rectangle Style="{DynamicResource ToolbarSep}"/>

                    <!-- Exportar -->
                    <Button Style="{DynamicResource BtnGhost}"
                            Click="BtnExport_Click"
                            Padding="18,9" MinHeight="34" Margin="10,0,10,0">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="↓"
                                       FontSize="14"
                                       VerticalAlignment="Center"
                                       Foreground="{DynamicResource AccentCyanBrush}"
                                       Margin="0,0,8,0"/>
                            <TextBlock Text="Exportar PCAP"
                                       FontFamily="{DynamicResource UiFont}"
                                       FontSize="12"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Rectangle Style="{DynamicResource ToolbarSep}"/>

                    <!-- Filtro rápido visual -->
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="PROTO:" Style="{DynamicResource LabelCaps}"
                                   VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <Border x:Name="FilterAll" Style="{DynamicResource ProtoBadge_TCP}"
                                Cursor="Hand" Margin="0,0,4,0"
                                MouseLeftButtonDown="FilterAll_Click">
                            <TextBlock Text="TODOS"
                                       FontFamily="{DynamicResource UiFont}"
                                       FontSize="9" FontWeight="Medium"
                                       Foreground="{DynamicResource AccentCyanBrush}"/>
                        </Border>
                        <Border Style="{DynamicResource ProtoBadge_UDP}"
                                Cursor="Hand" Margin="0,0,4,0">
                            <TextBlock Text="UDP"
                                       FontFamily="{DynamicResource UiFont}"
                                       FontSize="9" FontWeight="Medium"
                                       Foreground="{DynamicResource AccentPurpleBrush}"/>
                        </Border>
                        <Border Style="{DynamicResource ProtoBadge_DNS}"
                                Cursor="Hand" Margin="0,0,4,0">
                            <TextBlock Text="DNS"
                                       FontFamily="{DynamicResource UiFont}"
                                       FontSize="9" FontWeight="Medium"
                                       Foreground="{DynamicResource AccentAmberBrush}"/>
                        </Border>
                        <Border Style="{DynamicResource ProtoBadge_TLS}"
                                Cursor="Hand">
                            <TextBlock Text="TLS"
                                       FontFamily="{DynamicResource UiFont}"
                                       FontSize="9" FontWeight="Medium"
                                       Foreground="{DynamicResource AccentRedBrush}"/>
                        </Border>
                    </StackPanel>

                    <!-- Spacer empuja la búsqueda a la derecha -->
                    <Grid Width="{Binding ActualWidth,
                                  RelativeSource={RelativeSource FindAncestor, AncestorType=StackPanel}}"
                          HorizontalAlignment="Stretch"/>

                    <!-- Caja de búsqueda -->
                    <StackPanel Orientation="Horizontal"
                                VerticalAlignment="Center"
                                HorizontalAlignment="Right">
                        <TextBlock Text="⌕"
                                   FontSize="14"
                                   Foreground="{DynamicResource TextTertiaryBrush}"
                                   VerticalAlignment="Center"
                                   Margin="0,0,6,0"/>
                        <TextBox x:Name="TxtSearch"
                                 Style="{DynamicResource SearchBox}"
                                 Width="200"
                                 VerticalContentAlignment="Center"
                                 TextChanged="TxtSearch_TextChanged">
                            <TextBox.Resources>
                                <Style TargetType="Border" BasedOn="{StaticResource {x:Type Border}}"/>
                            </TextBox.Resources>
                        </TextBox>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- ══════════════════════════════════════════════════════
                 BARRA DE ESTADÍSTICAS EN TIEMPO REAL
                 ══════════════════════════════════════════════════════ -->
            <Border Grid.Row="2"
                    Background="{DynamicResource BgSurfaceBrush}"
                    BorderBrush="{DynamicResource BorderSubtleBrush}"
                    BorderThickness="0,0,0,0.5">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Stretch">

                    <!-- Estado: indicador pulsante -->
                    <Border Style="{DynamicResource StatChip}">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse x:Name="LiveDot" Width="6" Height="6"
                                     Fill="{DynamicResource AccentGreenBrush}"
                                     VerticalAlignment="Center" Margin="0,0,6,0">
                                <Ellipse.Triggers>
                                    <EventTrigger RoutedEvent="Loaded">
                                        <BeginStoryboard>
                                            <Storyboard RepeatBehavior="Forever">
                                                <DoubleAnimation
                                                    Storyboard.TargetProperty="Opacity"
                                                    From="1" To="0.2"
                                                    Duration="0:0:0.8"
                                                    AutoReverse="True"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </EventTrigger>
                                </Ellipse.Triggers>
                            </Ellipse>
                            <TextBlock Style="{DynamicResource LabelCaps}"
                                       Text="ESTADO  " Margin="0,0,4,0"
                                       VerticalAlignment="Center"/>
                            <TextBlock x:Name="TxtStatus"
                                       Text="Capturando"
                                       FontFamily="{DynamicResource UiFont}"
                                       FontSize="10" FontWeight="Medium"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{DynamicResource StatChip}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Style="{DynamicResource LabelCaps}"
                                       Text="TOTAL  " Margin="0,0,4,0"
                                       VerticalAlignment="Center"/>
                            <TextBlock x:Name="TxtTotalPkts" Text="0"
                                       FontFamily="{DynamicResource MonoFont}"
                                       FontSize="11" FontWeight="Medium"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{DynamicResource StatChip}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Style="{DynamicResource LabelCaps}"
                                       Text="TCP  " Margin="0,0,4,0"
                                       VerticalAlignment="Center"/>
                            <TextBlock x:Name="TxtTcpCount" Text="0"
                                       FontFamily="{DynamicResource MonoFont}"
                                       FontSize="11"
                                       Foreground="{DynamicResource AccentCyanBrush}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{DynamicResource StatChip}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Style="{DynamicResource LabelCaps}"
                                       Text="UDP  " Margin="0,0,4,0"
                                       VerticalAlignment="Center"/>
                            <TextBlock x:Name="TxtUdpCount" Text="0"
                                       FontFamily="{DynamicResource MonoFont}"
                                       FontSize="11"
                                       Foreground="{DynamicResource AccentPurpleBrush}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{DynamicResource StatChip}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Style="{DynamicResource LabelCaps}"
                                       Text="DNS  " Margin="0,0,4,0"
                                       VerticalAlignment="Center"/>
                            <TextBlock x:Name="TxtDnsCount" Text="0"
                                       FontFamily="{DynamicResource MonoFont}"
                                       FontSize="11"
                                       Foreground="{DynamicResource AccentAmberBrush}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{DynamicResource StatChip}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Style="{DynamicResource LabelCaps}"
                                       Text="ALERTAS  " Margin="0,0,4,0"
                                       VerticalAlignment="Center"/>
                            <TextBlock x:Name="TxtAlerts" Text="0"
                                       FontFamily="{DynamicResource MonoFont}"
                                       FontSize="11"
                                       Foreground="{DynamicResource AccentRedBrush}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>

            <!-- ══════════════════════════════════════════════════════
                 ÁREA PRINCIPAL  (Sidebar + DataGrid)
                 ══════════════════════════════════════════════════════ -->
            <Grid Grid.Row="3">
                <Grid.ColumnDefinitions>
                    <!-- Sidebar: ancho se anima desde code-behind -->
                    <ColumnDefinition x:Name="SidebarColumn" Width="200"/>
                    <!-- Separador visual -->
                    <ColumnDefinition Width="0.5"/>
                    <!-- Contenido principal -->
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- ══ SIDEBAR ══════════════════════════════════════ -->
                <Border Grid.Column="0"
                        Background="{DynamicResource BgSurfaceBrush}"
                        ClipToBounds="True">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Navegación principal -->
                        <ScrollViewer Grid.Row="0"
                                      VerticalScrollBarVisibility="Hidden"
                                      HorizontalScrollBarVisibility="Hidden">
                            <StackPanel Margin="0,8,0,0">

                                <!-- Sección: Captura -->
                                <TextBlock x:Name="LblCaptura"
                                           Text="CAPTURA"
                                           Style="{DynamicResource LabelCaps}"
                                           Margin="14,8,0,4"
                                           Visibility="{Binding IsSidebarExpanded,
                                               RelativeSource={RelativeSource AncestorType=Window},
                                               Converter={StaticResource BoolToVis}}"/>

                                <ListBox x:Name="NavList"
                                         Background="Transparent"
                                         BorderThickness="0"
                                         SelectionChanged="NavList_SelectionChanged">
                                    <ListBox.ItemContainerStyle>
                                        <Style TargetType="ListBoxItem"
                                               BasedOn="{StaticResource NavItem}"/>
                                    </ListBox.ItemContainerStyle>

                                    <!-- Paquetes -->
                                    <ListBoxItem IsSelected="True">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="◉"
                                                       FontSize="14"
                                                       Foreground="{DynamicResource AccentCyanBrush}"
                                                       VerticalAlignment="Center"
                                                       Margin="0,0,10,0"/>
                                            <TextBlock x:Name="NavLblPackets"
                                                       Text="Paquetes"
                                                       FontFamily="{DynamicResource UiFont}"
                                                       FontSize="12"
                                                       VerticalAlignment="Center"/>
                                            <Border Background="{DynamicResource AccentCyanDimBrush}"
                                                    CornerRadius="3" Padding="5,1"
                                                    Margin="8,0,0,0"
                                                    VerticalAlignment="Center">
                                                <TextBlock Text="LIVE"
                                                           FontFamily="{DynamicResource MonoFont}"
                                                           FontSize="8"
                                                           Foreground="{DynamicResource AccentCyanBrush}"/>
                                            </Border>
                                        </StackPanel>
                                    </ListBoxItem>

                                    <!-- Filtros -->
                                    <ListBoxItem>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="⊟"
                                                       FontSize="14"
                                                       VerticalAlignment="Center"
                                                       Margin="0,0,10,0"/>
                                            <TextBlock Text="Filtros"
                                                       FontFamily="{DynamicResource UiFont}"
                                                       FontSize="12"
                                                       VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </ListBoxItem>
                                </ListBox>

                                <!-- Sección: Herramientas -->
                                <TextBlock Text="HERRAMIENTAS"
                                           Style="{DynamicResource LabelCaps}"
                                           Margin="14,16,0,4"
                                           Visibility="{Binding IsSidebarExpanded,
                                               RelativeSource={RelativeSource AncestorType=Window},
                                               Converter={StaticResource BoolToVis}}"/>

                                <ListBox Background="Transparent" BorderThickness="0">
                                    <ListBox.ItemContainerStyle>
                                        <Style TargetType="ListBoxItem"
                                               BasedOn="{StaticResource NavItem}"/>
                                    </ListBox.ItemContainerStyle>

                                    <ListBoxItem>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="⬡"
                                                       FontSize="14"
                                                       VerticalAlignment="Center"
                                                       Margin="0,0,10,0"/>
                                            <TextBlock Text="ARP Scanner"
                                                       FontFamily="{DynamicResource UiFont}"
                                                       FontSize="12"
                                                       VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </ListBoxItem>

                                    <ListBoxItem>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="⌖"
                                                       FontSize="14"
                                                       VerticalAlignment="Center"
                                                       Margin="0,0,10,0"/>
                                            <TextBlock Text="Nmap"
                                                       FontFamily="{DynamicResource UiFont}"
                                                       FontSize="12"
                                                       VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </ListBoxItem>

                                    <ListBoxItem>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="⊕"
                                                       FontSize="14"
                                                       VerticalAlignment="Center"
                                                       Margin="0,0,10,0"/>
                                            <TextBlock Text="IP Lookup"
                                                       FontFamily="{DynamicResource UiFont}"
                                                       FontSize="12"
                                                       VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </ListBoxItem>
                                </ListBox>
                            </StackPanel>
                        </ScrollViewer>

                        <!-- Pie del sidebar: Ajustes + Colapsar -->
                        <StackPanel Grid.Row="1" Margin="6,0,6,8">
                            <Rectangle Height="0.5"
                                       Fill="{DynamicResource BorderSubtleBrush}"
                                       Margin="4,0,4,6"/>

                            <!-- Ajustes -->
                            <Border Cursor="Hand" Padding="10,8" CornerRadius="6"
                                    Background="Transparent"
                                    MouseLeftButtonDown="NavSettings_Click">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="⚙"
                                               FontSize="14"
                                               Foreground="{DynamicResource TextTertiaryBrush}"
                                               VerticalAlignment="Center"
                                               Margin="0,0,10,0"/>
                                    <TextBlock Text="Ajustes"
                                               FontFamily="{DynamicResource UiFont}"
                                               FontSize="12"
                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                               VerticalAlignment="Center"
                                               Visibility="{Binding IsSidebarExpanded,
                                                   RelativeSource={RelativeSource AncestorType=Window},
                                                   Converter={StaticResource BoolToVis}}"/>
                                </StackPanel>
                            </Border>

                            <!-- Colapsar -->
                            <Border Cursor="Hand" Padding="10,8" CornerRadius="6"
                                    Background="Transparent"
                                    MouseLeftButtonDown="BtnToggleSidebar_Click">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock x:Name="TxtToggleIcon"
                                               Text="◁◁"
                                               FontSize="11"
                                               Foreground="{DynamicResource TextTertiaryBrush}"
                                               VerticalAlignment="Center"
                                               Margin="0,0,10,0"/>
                                    <TextBlock x:Name="TxtToggleLabel"
                                               Text="Colapsar"
                                               FontFamily="{DynamicResource UiFont}"
                                               FontSize="12"
                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                               VerticalAlignment="Center"
                                               Visibility="{Binding IsSidebarExpanded,
                                                   RelativeSource={RelativeSource AncestorType=Window},
                                                   Converter={StaticResource BoolToVis}}"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Separador vertical -->
                <Rectangle Grid.Column="1"
                           Fill="{DynamicResource BorderSubtleBrush}"/>

                <!-- ══ PANEL PRINCIPAL: DataGrid ══════════════════════ -->
                <Grid Grid.Column="2" Background="{DynamicResource BgPrimaryBrush}">
                    <!-- DataGrid de paquetes -->
                    <DataGrid x:Name="PacketGrid"
                              Style="{DynamicResource PacketGrid}"
                              ColumnHeaderStyle="{DynamicResource PacketGridColumnHeader}"
                              RowStyle="{DynamicResource PacketGridRow}"
                              CellStyle="{DynamicResource PacketGridCell}"
                              ItemsSource="{Binding FilteredPackets}"
                              VirtualizingPanel.ScrollUnit="Pixel"
                              EnableRowVirtualization="True"
                              SelectedItem="{Binding SelectedPacket}">

                        <!-- Scrollbar personalizada -->
                        <DataGrid.Resources>
                            <Style TargetType="ScrollBar"
                                   BasedOn="{StaticResource FlatScrollBar}"/>
                        </DataGrid.Resources>

                        <DataGrid.Columns>

                            <!-- # ID -->
                            <DataGridTextColumn Header="#"
                                                Binding="{Binding Id}"
                                                Width="48">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="{DynamicResource TextTertiaryBrush}"/>
                                        <Setter Property="FontFamily" Value="{DynamicResource MonoFont}"/>
                                        <Setter Property="FontSize" Value="10"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                        <Setter Property="Margin" Value="12,0"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <!-- Tiempo -->
                            <DataGridTextColumn Header="Tiempo"
                                                Binding="{Binding Timestamp, StringFormat=HH:mm:ss.fff}"
                                                Width="120">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="{DynamicResource TextTertiaryBrush}"/>
                                        <Setter Property="FontFamily" Value="{DynamicResource MonoFont}"/>
                                        <Setter Property="FontSize" Value="10"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                        <Setter Property="Margin" Value="12,0"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <!-- IP Origen -->
                            <DataGridTextColumn Header="IP Origen"
                                                Binding="{Binding SourceIp}"
                                                Width="140">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                                        <Setter Property="FontFamily" Value="{DynamicResource MonoFont}"/>
                                        <Setter Property="FontSize" Value="11"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                        <Setter Property="Margin" Value="12,0"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <!-- IP Destino -->
                            <DataGridTextColumn Header="IP Destino"
                                                Binding="{Binding DestinationIp}"
                                                Width="140">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                                        <Setter Property="FontFamily" Value="{DynamicResource MonoFont}"/>
                                        <Setter Property="FontSize" Value="11"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                        <Setter Property="Margin" Value="12,0"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <!-- Puerto -->
                            <DataGridTextColumn Header="Puerto"
                                                Binding="{Binding Port}"
                                                Width="72">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                                        <Setter Property="FontFamily" Value="{DynamicResource MonoFont}"/>
                                        <Setter Property="FontSize" Value="11"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                        <Setter Property="Margin" Value="12,0"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <!-- Protocolo (badge de color) -->
                            <DataGridTemplateColumn Header="Protocolo" Width="90">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Grid Margin="12,0">
                                            <!-- TCP -->
                                            <Border Style="{DynamicResource ProtoBadge_TCP}"
                                                    Visibility="{Binding IsTcp,
                                                        Converter={StaticResource BoolToVis}}">
                                                <TextBlock Text="TCP"
                                                           FontFamily="{DynamicResource UiFont}"
                                                           FontSize="9" FontWeight="Medium"
                                                           Foreground="{DynamicResource AccentCyanBrush}"/>
                                            </Border>
                                            <!-- UDP -->
                                            <Border Style="{DynamicResource ProtoBadge_UDP}"
                                                    Visibility="{Binding IsUdp,
                                                        Converter={StaticResource BoolToVis}}">
                                                <TextBlock Text="UDP"
                                                           FontFamily="{DynamicResource UiFont}"
                                                           FontSize="9" FontWeight="Medium"
                                                           Foreground="{DynamicResource AccentPurpleBrush}"/>
                                            </Border>
                                            <!-- HTTP -->
                                            <Border Style="{DynamicResource ProtoBadge_HTTP}"
                                                    Visibility="{Binding IsHttp,
                                                        Converter={StaticResource BoolToVis}}">
                                                <TextBlock Text="HTTP"
                                                           FontFamily="{DynamicResource UiFont}"
                                                           FontSize="9" FontWeight="Medium"
                                                           Foreground="{DynamicResource AccentGreenBrush}"/>
                                            </Border>
                                            <!-- DNS -->
                                            <Border Style="{DynamicResource ProtoBadge_DNS}"
                                                    Visibility="{Binding IsDns,
                                                        Converter={StaticResource BoolToVis}}">
                                                <TextBlock Text="DNS"
                                                           FontFamily="{DynamicResource UiFont}"
                                                           FontSize="9" FontWeight="Medium"
                                                           Foreground="{DynamicResource AccentAmberBrush}"/>
                                            </Border>
                                            <!-- TLS -->
                                            <Border Style="{DynamicResource ProtoBadge_TLS}"
                                                    Visibility="{Binding IsTls,
                                                        Converter={StaticResource BoolToVis}}">
                                                <TextBlock Text="TLS"
                                                           FontFamily="{DynamicResource UiFont}"
                                                           FontSize="9" FontWeight="Medium"
                                                           Foreground="{DynamicResource AccentRedBrush}"/>
                                            </Border>
                                        </Grid>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <!-- País -->
                            <DataGridTextColumn Header="País"
                                                Binding="{Binding Country}"
                                                Width="120">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                                        <Setter Property="FontFamily" Value="{DynamicResource UiFont}"/>
                                        <Setter Property="FontSize" Value="11"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                        <Setter Property="Margin" Value="12,0"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <!-- ISP -->
                            <DataGridTextColumn Header="ISP"
                                                Binding="{Binding Isp}"
                                                Width="*">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="{DynamicResource TextTertiaryBrush}"/>
                                        <Setter Property="FontFamily" Value="{DynamicResource UiFont}"/>
                                        <Setter Property="FontSize" Value="11"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                        <Setter Property="Margin" Value="12,0"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <!-- Tamaño con mini barra -->
                            <DataGridTemplateColumn Header="Tamaño" Width="110">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal"
                                                    VerticalAlignment="Center"
                                                    Margin="12,0">
                                            <TextBlock Text="{Binding SizeBytes, StringFormat={}{0} B}"
                                                       FontFamily="{DynamicResource MonoFont}"
                                                       FontSize="10"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                       VerticalAlignment="Center"
                                                       Margin="0,0,6,0"/>
                                            <!-- Barra proporcional al tamaño -->
                                            <Rectangle Width="{Binding SizeBarWidth}"
                                                       Height="3"
                                                       RadiusX="1" RadiusY="1"
                                                       Fill="{DynamicResource AccentCyanDimBrush}"
                                                       VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                        </DataGrid.Columns>

                        <!-- Animación de entrada para cada fila nueva -->
                        <DataGrid.ItemContainerStyle>
                            <Style TargetType="DataGridRow"
                                   BasedOn="{StaticResource PacketGridRow}">
                                <EventSetter Event="Loaded"
                                             Handler="DataGridRow_Loaded"/>
                            </Style>
                        </DataGrid.ItemContainerStyle>

                    </DataGrid>

                    <!-- Panel vacío si no hay paquetes -->
                    <StackPanel HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Visibility="{Binding HasNoPackets,
                                    Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="◎"
                                   FontSize="48"
                                   Foreground="{DynamicResource BorderNormalBrush}"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,12"/>
                        <TextBlock Text="Sin paquetes capturados"
                                   FontFamily="{DynamicResource UiFont}"
                                   FontSize="14"
                                   Foreground="{DynamicResource TextTertiaryBrush}"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="Selecciona una interfaz y presiona Capturar"
                                   FontFamily="{DynamicResource UiFont}"
                                   FontSize="11"
                                   Foreground="{DynamicResource TextTertiaryBrush}"
                                   HorizontalAlignment="Center"
                                   Margin="0,4,0,0"/>
                    </StackPanel>
                </Grid>
            </Grid>

            <!-- ══════════════════════════════════════════════════════
                 BARRA DE ESTADO INFERIOR
                 ══════════════════════════════════════════════════════ -->
            <Border Grid.Row="4"
                    Background="{DynamicResource BgSurfaceBrush}"
                    CornerRadius="0,0,10,10"
                    BorderBrush="{DynamicResource BorderSubtleBrush}"
                    BorderThickness="0,0.5,0,0">
                <Grid Margin="12,0">
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Center">
                        <TextBlock Style="{DynamicResource LabelCaps}"
                                   VerticalAlignment="Center">
                            <Run Text="INTERFAZ: "/>
                        </TextBlock>
                        <TextBlock x:Name="TxtStatusIface"
                                   Text="eth0"
                                   FontFamily="{DynamicResource MonoFont}"
                                   FontSize="9"
                                   Foreground="{DynamicResource AccentGreenBrush}"
                                   VerticalAlignment="Center"
                                   Margin="0,0,12,0"/>
                        <TextBlock Style="{DynamicResource LabelCaps}"
                                   VerticalAlignment="Center">
                            <Run Text="SESIÓN: "/>
                        </TextBlock>
                        <TextBlock x:Name="TxtSessionTime"
                                   Text="00:00:00"
                                   FontFamily="{DynamicResource MonoFont}"
                                   FontSize="9"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                    <TextBlock HorizontalAlignment="Right"
                               VerticalAlignment="Center"
                               FontFamily="{DynamicResource MonoFont}"
                               FontSize="9"
                               Foreground="{DynamicResource TextTertiaryBrush}"
                               Text="CyberSniff v2.0  ·  .NET 6  ·  WPF  ·  SharpPcap"/>
                </Grid>
            </Border>

        </Grid>
    </Border>
</Window>
