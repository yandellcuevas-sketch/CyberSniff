<Window x:Class="CyberSniff.Windows.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:window="clr-namespace:CyberSniff.Windows"
        mc:Ignorable="d"
        x:Name="Window"
        Title="CyberSniff"
        Height="720" Width="1280"
        MinHeight="540" MinWidth="960"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="CanResizeWithGrip"
        WindowStartupLocation="CenterScreen"
        MaxWidth="{Binding Source={x:Static SystemParameters.WorkArea}, Path=Width}"
        MaxHeight="{Binding Source={x:Static SystemParameters.WorkArea}, Path=Height}"
        Closing="Window_Closing">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>

    <!-- WindowChrome para drag y controles personalizados -->
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="44"
                      ResizeBorderThickness="5"
                      CornerRadius="12"
                      GlassFrameThickness="0"
                      UseAeroCaptionButtons="False"/>
    </WindowChrome.WindowChrome>

    <!-- ── Raíz con glassmorphism y sombra exterior ── -->
    <Border x:Name="Border"
            CornerRadius="12"
            Background="{DynamicResource BgPrimaryBrush}"
            BorderBrush="{DynamicResource BorderNormalBrush}"
            BorderThickness="0.5">
        <Border.Effect>
            <DropShadowEffect BlurRadius="48" ShadowDepth="0"
                              Color="#CC000000" Opacity="0.75"/>
        </Border.Effect>

        <materialDesign:DialogHost x:Name="DialogHost"
                                   IsOpen="{Binding IsDialogOpen, ElementName=Window}"
                                   DialogClosing="DialogHost_DialogClosing">
            <materialDesign:DialogHost.DialogContent>
                <StackPanel Margin="20">
                    <TextBlock Text="Add to labels" FontSize="16" Margin="0,0,0,14"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               FontFamily="{DynamicResource UiFont}"/>
                    <TextBox x:Name="TextHost" materialDesign:HintAssist.Hint="IP Address"
                             Style="{StaticResource MaterialDesignOutlinedTextBox}"
                             Margin="0,0,0,10" Foreground="White"/>
                    <TextBox x:Name="TextLabel" materialDesign:HintAssist.Hint="Label"
                             Style="{StaticResource MaterialDesignOutlinedTextBox}"
                             Margin="0,0,0,16" Foreground="White"/>
                    <Button Style="{StaticResource MaterialDesignFlatButton}"
                            Command="{x:Static materialDesign:DialogHost.CloseDialogCommand}"
                            Content="SAVE" HorizontalAlignment="Right"/>
                </StackPanel>
            </materialDesign:DialogHost.DialogContent>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="44"/>   <!-- Barra de título -->
                    <RowDefinition Height="56"/>   <!-- Toolbar -->
                    <RowDefinition Height="30"/>   <!-- Barra de estadísticas -->
                    <RowDefinition Height="*"/>    <!-- Área principal -->
                    <RowDefinition Height="24"/>   <!-- Status bar -->
                </Grid.RowDefinitions>

                <!-- ══════════════════════════════════════════════════════
                     BARRA DE TÍTULO PERSONALIZADA
                     ══════════════════════════════════════════════════════ -->
                <Border x:Name="TopBox"
                        Grid.Row="0"
                        Background="{DynamicResource BgSurfaceBrush}"
                        CornerRadius="12,12,0,0"
                        BorderBrush="{DynamicResource BorderSubtleBrush}"
                        BorderThickness="0,0,0,0.5">

                    <Grid Margin="14,0,14,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>  <!-- Controles macOS -->
                            <ColumnDefinition Width="Auto"/>  <!-- Logo -->
                            <ColumnDefinition Width="*"/>     <!-- Spacer -->
                            <ColumnDefinition Width="Auto"/>  <!-- Métricas live -->
                            <ColumnDefinition Width="Auto"/>  <!-- Botones Windows -->
                        </Grid.ColumnDefinitions>

                        <!-- Botones macOS-style -->
                        <StackPanel Grid.Column="0"
                                    Orientation="Horizontal"
                                    VerticalAlignment="Center"
                                    Margin="0,0,18,0"
                                    WindowChrome.IsHitTestVisibleInChrome="True">
                            <!-- Cerrar -->
                            <Button x:Name="CloseButton" Width="13" Height="13"
                                    Command="{x:Static window:MainWindow.HandleCaptions}"
                                    Cursor="Hand" Style="{x:Null}" BorderThickness="0"
                                    ToolTip="Cerrar">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Ellipse Width="13" Height="13"
                                                 Fill="{DynamicResource AccentRedBrush}">
                                            <Ellipse.Effect>
                                                <DropShadowEffect BlurRadius="5" ShadowDepth="0"
                                                                  Color="#FFEF4444" Opacity="0.5"/>
                                            </Ellipse.Effect>
                                        </Ellipse>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                            <!-- Minimizar -->
                            <Button x:Name="MinButton" Width="13" Height="13"
                                    Command="{x:Static window:MainWindow.HandleCaptions}"
                                    Cursor="Hand" Style="{x:Null}" BorderThickness="0"
                                    Margin="7,0,0,0" ToolTip="Minimizar">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Ellipse Width="13" Height="13"
                                                 Fill="{DynamicResource AccentAmberBrush}">
                                            <Ellipse.Effect>
                                                <DropShadowEffect BlurRadius="5" ShadowDepth="0"
                                                                  Color="#FFF59E0B" Opacity="0.5"/>
                                            </Ellipse.Effect>
                                        </Ellipse>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                            <!-- Maximizar -->
                            <Button x:Name="MaxButton" Width="13" Height="13"
                                    Command="{x:Static window:MainWindow.HandleCaptions}"
                                    Cursor="Hand" Style="{x:Null}" BorderThickness="0"
                                    Margin="7,0,0,0" ToolTip="Maximizar">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Ellipse Width="13" Height="13"
                                                 Fill="{DynamicResource AccentGreenBrush}">
                                            <Ellipse.Effect>
                                                <DropShadowEffect BlurRadius="5" ShadowDepth="0"
                                                                  Color="#FF10B981" Opacity="0.5"/>
                                            </Ellipse.Effect>
                                        </Ellipse>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </StackPanel>

                        <!-- Logo y nombre -->
                        <StackPanel Grid.Column="1"
                                    Orientation="Horizontal"
                                    VerticalAlignment="Center"
                                    WindowChrome.IsHitTestVisibleInChrome="False">
                            <!-- Punto de acento pulsante -->
                            <Ellipse Width="8" Height="8" Margin="0,0,9,0"
                                     Fill="{DynamicResource AccentCyanBrush}">
                                <Ellipse.Effect>
                                    <DropShadowEffect BlurRadius="8" ShadowDepth="0"
                                                      Color="{DynamicResource AccentCyanColor}"
                                                      Opacity="0.9"/>
                                </Ellipse.Effect>
                                <Ellipse.Triggers>
                                    <EventTrigger RoutedEvent="Loaded">
                                        <BeginStoryboard>
                                            <Storyboard RepeatBehavior="Forever">
                                                <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                 From="1" To="0.3"
                                                                 Duration="0:0:1.4"
                                                                 AutoReverse="True"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </EventTrigger>
                                </Ellipse.Triggers>
                            </Ellipse>
                            <TextBlock x:Name="WindowTitleText"
                                       Text="CYBERSNIFF"
                                       FontFamily="{DynamicResource UiFont}"
                                       FontSize="13" FontWeight="Bold"
                                       Foreground="{DynamicResource AccentCyanBrush}"
                                       VerticalAlignment="Center"
                                       Typography.Kerning="True">
                                <TextBlock.Effect>
                                    <DropShadowEffect BlurRadius="6" ShadowDepth="0"
                                                      Color="{DynamicResource AccentCyanColor}"
                                                      Opacity="0.4"/>
                                </TextBlock.Effect>
                            </TextBlock>
                            <TextBlock Text=" v3.2"
                                       FontFamily="{DynamicResource MonoFont}"
                                       FontSize="10"
                                       Foreground="{DynamicResource TextTertiaryBrush}"
                                       VerticalAlignment="Center"
                                       Margin="5,0,0,0"/>
                        </StackPanel>

                        <!-- Métricas en tiempo real -->
                        <StackPanel Grid.Column="3"
                                    Orientation="Horizontal"
                                    VerticalAlignment="Center"
                                    Margin="0,0,12,0"
                                    WindowChrome.IsHitTestVisibleInChrome="False">
                            <Border Background="{DynamicResource BgSurface2Brush}"
                                    BorderBrush="{DynamicResource BorderSubtleBrush}"
                                    BorderThickness="0.5" CornerRadius="5"
                                    Padding="10,4" Margin="0,0,6,0">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="IFACE: " Style="{DynamicResource LabelCaps}"/>
                                    <TextBlock x:Name="TxtIface" Text="—"
                                               FontFamily="{DynamicResource MonoFont}"
                                               FontSize="10"
                                               Foreground="{DynamicResource AccentGreenBrush}"/>
                                </StackPanel>
                            </Border>
                            <Border Background="{DynamicResource BgSurface2Brush}"
                                    BorderBrush="{DynamicResource BorderSubtleBrush}"
                                    BorderThickness="0.5" CornerRadius="5"
                                    Padding="10,4" Margin="0,0,6,0">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="PKTS: " Style="{DynamicResource LabelCaps}"/>
                                    <TextBlock x:Name="TxtTitlePkts" Text="0"
                                               FontFamily="{DynamicResource MonoFont}"
                                               FontSize="10"
                                               Foreground="{DynamicResource AccentCyanBrush}"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- ══════════════════════════════════════════════════════
                     TOOLBAR
                     ══════════════════════════════════════════════════════ -->
                <Border Grid.Row="1"
                        Background="{DynamicResource BgSurface2Brush}"
                        BorderBrush="{DynamicResource BorderSubtleBrush}"
                        BorderThickness="0,0,0,0.5">
                    <StackPanel Orientation="Horizontal"
                                VerticalAlignment="Center"
                                Margin="18,0">

                        <!-- Adaptador de red -->
                        <ComboBox x:Name="NetworkAdapterComboBox"
                                  Width="260" Height="36"
                                  Margin="0,0,10,0"
                                  FontFamily="{DynamicResource MonoFont}"
                                  FontSize="11"
                                  Foreground="{DynamicResource TextPrimaryBrush}"
                                  IsEnabled="{Binding IsSniffing, Converter={StaticResource InverseBooleanConverter}, ElementName=Window}"
                                  SelectionChanged="NetworkAdapterComboBox_SelectionChanged"
                                  Style="{StaticResource MaterialDesignFloatingHintComboBox}"
                                  ToolTip="Pick a network adapter">
                            <materialDesign:HintAssist.Hint>
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="NetworkOutline"/>
                                    <TextBlock Text=" Adapter"/>
                                </StackPanel>
                            </materialDesign:HintAssist.Hint>
                        </ComboBox>

                        <!-- Info del adaptador -->
                        <Button x:Name="AdapterInfoButton"
                                Width="36" Height="36" Margin="0,0,4,0"
                                materialDesign:ButtonAssist.CornerRadius="8"
                                Command="{x:Static window:MainWindow.OpenAdapter}"
                                Cursor="Hand"
                                Style="{DynamicResource BtnGhost}"
                                ToolTip="Show adapter info">
                            <materialDesign:PackIcon Kind="InfoCircleOutline" Width="16" Height="16"
                                                     Foreground="{DynamicResource TextSecondaryBrush}"/>
                        </Button>

                        <!-- Refresh adaptadores -->
                        <Button Width="36" Height="36" Margin="0,0,12,0"
                                materialDesign:ButtonAssist.CornerRadius="8"
                                Command="{x:Static window:MainWindow.RefreshAdaptersCommand}"
                                Cursor="Hand"
                                IsEnabled="{Binding IsSniffing, Converter={StaticResource InverseBooleanConverter}, ElementName=Window}"
                                Style="{DynamicResource BtnGhost}"
                                ToolTip="Refresh adapters">
                            <materialDesign:PackIcon Kind="Refresh" Width="16" Height="16"
                                                     Foreground="{DynamicResource TextSecondaryBrush}"/>
                        </Button>

                        <Rectangle Style="{DynamicResource ToolbarSep}"/>

                        <!-- Capturar / Detener -->
                        <Button x:Name="SniffButton"
                                Padding="20,10" MinHeight="36" Margin="12,0,8,0"
                                materialDesign:ButtonAssist.CornerRadius="8"
                                Command="{x:Static window:MainWindow.ToggleCapture}"
                                Cursor="Hand"
                                IsEnabled="{Binding IsSniffing, Converter={StaticResource InverseBooleanConverter}, ElementName=Window}"
                                Style="{DynamicResource BtnSuccess}"
                                ToolTip="Start / stop capturing traffic">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <materialDesign:PackIcon x:Name="SniffIcon"
                                                         Kind="Search"
                                                         Width="14" Height="14"
                                                         Margin="0,0,8,0"/>
                                <TextBlock x:Name="SniffText" Text="CAPTURAR"
                                           FontFamily="{DynamicResource UiFont}"
                                           FontWeight="SemiBold" FontSize="11"/>
                            </StackPanel>
                        </Button>

                        <!-- Limpiar -->
                        <Button Width="36" Height="36" Margin="0,0,4,0"
                                materialDesign:ButtonAssist.CornerRadius="8"
                                Command="{x:Static window:MainWindow.ClearAllCommand}"
                                Cursor="Hand"
                                Style="{DynamicResource BtnGhost}"
                                ToolTip="Clear all entries">
                            <materialDesign:PackIcon Kind="RubbishBinOutline" Width="16" Height="16"
                                                     Foreground="{DynamicResource TextSecondaryBrush}"/>
                        </Button>

                        <Rectangle Style="{DynamicResource ToolbarSep}"/>

                        <!-- Filtros -->
                        <Button x:Name="FilterButton"
                                Width="36" Height="36" Margin="4,0,4,0"
                                materialDesign:ButtonAssist.CornerRadius="8"
                                Command="{x:Static window:MainWindow.OpenFilters}"
                                Cursor="Hand"
                                IsEnabled="{Binding IsSniffing, Converter={StaticResource InverseBooleanConverter}, ElementName=Window}"
                                Style="{DynamicResource BtnGhost}"
                                ToolTip="Customize packet filtering">
                            <materialDesign:PackIcon Kind="FilterOutline" Width="16" Height="16"
                                                     Foreground="{DynamicResource AccentCyanBrush}"/>
                        </Button>

                        <!-- ARP -->
                        <Button x:Name="ArpButton"
                                Width="36" Height="36" Margin="0,0,4,0"
                                materialDesign:ButtonAssist.CornerRadius="8"
                                Command="{x:Static window:MainWindow.OpenArp}"
                                Cursor="Hand"
                                IsEnabled="{Binding IsSniffing, Converter={StaticResource InverseBooleanConverter}, ElementName=Window}"
                                Style="{DynamicResource BtnGhost}"
                                ToolTip="Open ARP poisoning window">
                            <materialDesign:PackIcon Kind="SkullCrossbonesOutline" Width="16" Height="16"
                                                     Foreground="{DynamicResource AccentRedBrush}"/>
                        </Button>

                        <!-- Settings -->
                        <Button x:Name="SettingsButton"
                                Width="36" Height="36" Margin="0,0,4,0"
                                materialDesign:ButtonAssist.CornerRadius="8"
                                Command="{x:Static window:MainWindow.OpenSettings}"
                                Cursor="Hand"
                                IsEnabled="{Binding IsSniffing, Converter={StaticResource InverseBooleanConverter}, ElementName=Window}"
                                Style="{DynamicResource BtnGhost}"
                                ToolTip="Configure CyberSniff">
                            <materialDesign:PackIcon Kind="SettingsOutline" Width="16" Height="16"
                                                     Foreground="{DynamicResource TextSecondaryBrush}"/>
                        </Button>
                    </StackPanel>
                </Border>

                <!-- ══════════════════════════════════════════════════════
                     BARRA DE ESTADÍSTICAS EN TIEMPO REAL
                     ══════════════════════════════════════════════════════ -->
                <Border Grid.Row="2"
                        Background="{DynamicResource BgSurfaceBrush}"
                        BorderBrush="{DynamicResource BorderSubtleBrush}"
                        BorderThickness="0,0,0,0.5">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Stretch">

                        <!-- Estado con indicador pulsante -->
                        <Border Style="{DynamicResource StatChip}">
                            <StackPanel Orientation="Horizontal">
                                <Ellipse x:Name="LiveDot" Width="6" Height="6"
                                         Fill="{DynamicResource AccentGreenBrush}"
                                         VerticalAlignment="Center" Margin="0,0,7,0">
                                    <Ellipse.Effect>
                                        <DropShadowEffect BlurRadius="4" ShadowDepth="0"
                                                          Color="#FF10B981" Opacity="0.7"/>
                                    </Ellipse.Effect>
                                    <Ellipse.Triggers>
                                        <EventTrigger RoutedEvent="Loaded">
                                            <BeginStoryboard>
                                                <Storyboard RepeatBehavior="Forever">
                                                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                     From="1" To="0.2"
                                                                     Duration="0:0:0.8"
                                                                     AutoReverse="True"/>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </EventTrigger>
                                    </Ellipse.Triggers>
                                </Ellipse>
                                <TextBlock Style="{DynamicResource LabelCaps}"
                                           Text="ESTADO  " Margin="0,0,4,0"
                                           VerticalAlignment="Center"/>
                                <TextBlock x:Name="TxtStatus"
                                           Text="Inactivo"
                                           FontFamily="{DynamicResource UiFont}"
                                           FontSize="10" FontWeight="Medium"
                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>

                        <Border Style="{DynamicResource StatChip}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Style="{DynamicResource LabelCaps}"
                                           Text="TOTAL  " Margin="0,0,4,0"
                                           VerticalAlignment="Center"/>
                                <TextBlock x:Name="TxtTotalPkts" Text="0"
                                           FontFamily="{DynamicResource MonoFont}"
                                           FontSize="11"
                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>

                        <Border Style="{DynamicResource StatChip}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Style="{DynamicResource LabelCaps}"
                                           Text="TCP  " Margin="0,0,4,0"
                                           VerticalAlignment="Center"/>
                                <TextBlock x:Name="TxtTcpCount" Text="0"
                                           FontFamily="{DynamicResource MonoFont}"
                                           FontSize="11"
                                           Foreground="{DynamicResource AccentCyanBrush}"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>

                        <Border Style="{DynamicResource StatChip}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Style="{DynamicResource LabelCaps}"
                                           Text="UDP  " Margin="0,0,4,0"
                                           VerticalAlignment="Center"/>
                                <TextBlock x:Name="TxtUdpCount" Text="0"
                                           FontFamily="{DynamicResource MonoFont}"
                                           FontSize="11"
                                           Foreground="{DynamicResource AccentPurpleBrush}"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>

                        <Border Style="{DynamicResource StatChip}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Style="{DynamicResource LabelCaps}"
                                           Text="DNS  " Margin="0,0,4,0"
                                           VerticalAlignment="Center"/>
                                <TextBlock x:Name="TxtDnsCount" Text="0"
                                           FontFamily="{DynamicResource MonoFont}"
                                           FontSize="11"
                                           Foreground="{DynamicResource AccentAmberBrush}"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- ══════════════════════════════════════════════════════
                     ÁREA PRINCIPAL (Sidebar + DataGrid + SidePanel)
                     ══════════════════════════════════════════════════════ -->
                <Grid Grid.Row="3">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition x:Name="SidebarColumn" Width="200"/>
                        <ColumnDefinition Width="0.5"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition x:Name="SidePanelColumn" Width="0"/>
                    </Grid.ColumnDefinitions>

                    <!-- ══ SIDEBAR ══ -->
                    <Border Grid.Column="0"
                            Background="{DynamicResource BgSurfaceBrush}"
                            ClipToBounds="True">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <ScrollViewer Grid.Row="0"
                                          VerticalScrollBarVisibility="Hidden"
                                          HorizontalScrollBarVisibility="Hidden">
                                <StackPanel Margin="0,10,0,0">

                                    <TextBlock Text="CAPTURA"
                                               Style="{DynamicResource LabelCaps}"
                                               Margin="14,8,0,6"/>

                                    <ListBox x:Name="NavList"
                                             Background="Transparent"
                                             BorderThickness="0"
                                             SelectionChanged="NavList_SelectionChanged">
                                        <ListBox.ItemContainerStyle>
                                            <Style TargetType="ListBoxItem"
                                                   BasedOn="{StaticResource NavItem}"/>
                                        </ListBox.ItemContainerStyle>

                                        <ListBoxItem IsSelected="True">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="◉" FontSize="14"
                                                           Foreground="{DynamicResource AccentCyanBrush}"
                                                           VerticalAlignment="Center"
                                                           Margin="0,0,11,0"/>
                                                <TextBlock Text="Paquetes"
                                                           FontFamily="{DynamicResource UiFont}"
                                                           FontSize="12"
                                                           VerticalAlignment="Center"/>
                                                <Border Background="{DynamicResource AccentCyanDimBrush}"
                                                        CornerRadius="3" Padding="5,1"
                                                        Margin="9,0,0,0" VerticalAlignment="Center">
                                                    <TextBlock Text="LIVE"
                                                               FontFamily="{DynamicResource MonoFont}"
                                                               FontSize="8"
                                                               Foreground="{DynamicResource AccentCyanBrush}"/>
                                                </Border>
                                            </StackPanel>
                                        </ListBoxItem>

                                        <ListBoxItem>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="⊟" FontSize="14"
                                                           VerticalAlignment="Center"
                                                           Margin="0,0,11,0"/>
                                                <TextBlock Text="Filtros"
                                                           FontFamily="{DynamicResource UiFont}"
                                                           FontSize="12"
                                                           VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </ListBoxItem>
                                    </ListBox>

                                    <TextBlock Text="HERRAMIENTAS"
                                               Style="{DynamicResource LabelCaps}"
                                               Margin="14,18,0,6"/>

                                    <ListBox Background="Transparent" BorderThickness="0">
                                        <ListBox.ItemContainerStyle>
                                            <Style TargetType="ListBoxItem"
                                                   BasedOn="{StaticResource NavItem}"/>
                                        </ListBox.ItemContainerStyle>

                                        <ListBoxItem>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="⬡" FontSize="14"
                                                           VerticalAlignment="Center"
                                                           Margin="0,0,11,0"/>
                                                <TextBlock Text="ARP Scanner"
                                                           FontFamily="{DynamicResource UiFont}"
                                                           FontSize="12"
                                                           VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </ListBoxItem>

                                        <ListBoxItem>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="⌖" FontSize="14"
                                                           VerticalAlignment="Center"
                                                           Margin="0,0,11,0"/>
                                                <TextBlock Text="Nmap"
                                                           FontFamily="{DynamicResource UiFont}"
                                                           FontSize="12"
                                                           VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </ListBoxItem>

                                        <ListBoxItem>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="⊕" FontSize="14"
                                                           VerticalAlignment="Center"
                                                           Margin="0,0,11,0"/>
                                                <TextBlock Text="IP Lookup"
                                                           FontFamily="{DynamicResource UiFont}"
                                                           FontSize="12"
                                                           VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </ListBoxItem>
                                    </ListBox>
                                </StackPanel>
                            </ScrollViewer>

                            <!-- Pie del sidebar -->
                            <StackPanel Grid.Row="1" Margin="6,0,6,10">
                                <Rectangle Height="0.5"
                                           Fill="{DynamicResource BorderSubtleBrush}"
                                           Margin="4,0,4,8"/>

                                <!-- Ajustes -->
                                <Border Cursor="Hand" Padding="10,9" CornerRadius="7"
                                        Background="Transparent"
                                        MouseLeftButtonDown="NavSettings_Click">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="⚙" FontSize="14"
                                                   Foreground="{DynamicResource TextTertiaryBrush}"
                                                   VerticalAlignment="Center"
                                                   Margin="0,0,11,0"/>
                                        <TextBlock Text="Ajustes"
                                                   FontFamily="{DynamicResource UiFont}"
                                                   FontSize="12"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>

                                <!-- Colapsar sidebar -->
                                <Border Cursor="Hand" Padding="10,9" CornerRadius="7"
                                        Background="Transparent"
                                        MouseLeftButtonDown="BtnToggleSidebar_Click">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock x:Name="TxtToggleIcon" Text="◁◁"
                                                   FontSize="11"
                                                   Foreground="{DynamicResource TextTertiaryBrush}"
                                                   VerticalAlignment="Center"
                                                   Margin="0,0,11,0"/>
                                        <TextBlock x:Name="TxtToggleLabel" Text="Colapsar"
                                                   FontFamily="{DynamicResource UiFont}"
                                                   FontSize="12"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Separador vertical -->
                    <Rectangle Grid.Column="1"
                               Fill="{DynamicResource BorderSubtleBrush}"/>

                    <!-- ══ PANEL PRINCIPAL: DataGrid ══ -->
                    <Grid Grid.Column="2" Background="{DynamicResource BgPrimaryBrush}">

                        <DataGrid x:Name="MainDataGrid"
                                  Style="{DynamicResource PacketGrid}"
                                  ColumnHeaderStyle="{DynamicResource PacketGridColumnHeader}"
                                  RowStyle="{DynamicResource PacketGridRow}"
                                  CellStyle="{DynamicResource PacketGridCell}"
                                  BeginningEdit="Grid_BeginningEdit"
                                  MouseDoubleClick="DataGridView_MouseDoubleClick"
                                  SelectionMode="Single"
                                  SelectionUnit="FullRow"
                                  VerticalGridLinesBrush="Transparent">

                            <DataGrid.Resources>
                                <Style TargetType="ScrollBar"
                                       BasedOn="{StaticResource FlatScrollBar}"/>
                            </DataGrid.Resources>

                            <DataGrid.Columns>
                                <DataGridTemplateColumn Header="FLAG" Width="42">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Image Source="{Binding Flag}"
                                                   Width="24" Height="16"
                                                   Margin="9,0"
                                                   VerticalAlignment="Center"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <DataGridTextColumn Header="IP ADDRESS"
                                                    Binding="{Binding IpAddress}"
                                                    Width="148">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                                            <Setter Property="FontFamily" Value="{DynamicResource MonoFont}"/>
                                            <Setter Property="FontSize" Value="11"/>
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                            <Setter Property="Margin" Value="8,0"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>

                                <DataGridTemplateColumn Header="PROTOCOL" Width="80">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border VerticalAlignment="Center" Margin="6,0"
                                                    CornerRadius="3" Padding="6,2">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="{DynamicResource AccentCyanDimBrush}"/>
                                                        <Setter Property="BorderBrush" Value="{DynamicResource AccentCyanBrush}"/>
                                                        <Setter Property="BorderThickness" Value="0.5"/>
                                                    </Style>
                                                </Border.Style>
                                                <TextBlock Text="{Binding Protocol}"
                                                           FontFamily="{DynamicResource MonoFont}"
                                                           FontSize="9" FontWeight="Medium"
                                                           Foreground="{DynamicResource AccentCyanBrush}"/>
                                            </Border>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <DataGridTextColumn Header="COUNTRY"
                                                    Binding="{Binding Country}"
                                                    Width="100">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                                            <Setter Property="FontFamily" Value="{DynamicResource UiFont}"/>
                                            <Setter Property="FontSize" Value="11"/>
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                            <Setter Property="Margin" Value="8,0"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>

                                <DataGridTextColumn Header="CITY"
                                                    Binding="{Binding City}"
                                                    Width="100">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                                            <Setter Property="FontFamily" Value="{DynamicResource UiFont}"/>
                                            <Setter Property="FontSize" Value="11"/>
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                            <Setter Property="Margin" Value="8,0"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>

                                <DataGridTextColumn Header="ISP"
                                                    Binding="{Binding Isp}"
                                                    Width="*">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="{DynamicResource TextTertiaryBrush}"/>
                                            <Setter Property="FontFamily" Value="{DynamicResource UiFont}"/>
                                            <Setter Property="FontSize" Value="11"/>
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                            <Setter Property="Margin" Value="8,0"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>

                                <DataGridTextColumn Header="PORT"
                                                    Binding="{Binding Port}"
                                                    Width="70">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                                            <Setter Property="FontFamily" Value="{DynamicResource MonoFont}"/>
                                            <Setter Property="FontSize" Value="11"/>
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                            <Setter Property="Margin" Value="8,0"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>

                                <DataGridTextColumn Header="LABEL"
                                                    Binding="{Binding Label}"
                                                    Width="90">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="{DynamicResource AccentAmberBrush}"/>
                                            <Setter Property="FontFamily" Value="{DynamicResource UiFont}"/>
                                            <Setter Property="FontSize" Value="10"/>
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                            <Setter Property="Margin" Value="8,0"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                            </DataGrid.Columns>

                            <DataGrid.ItemContainerStyle>
                                <Style TargetType="DataGridRow"
                                       BasedOn="{StaticResource PacketGridRow}">
                                    <EventSetter Event="Loaded" Handler="DataGridRow_Loaded"/>
                                </Style>
                            </DataGrid.ItemContainerStyle>

                            <DataGrid.ContextMenu>
                                <ContextMenu>
                                    <MenuItem Command="{x:Static window:MainWindow.CopyCommand}">
                                        <MenuItem.Icon>
                                            <materialDesign:PackIcon Kind="ClipboardOutline"/>
                                        </MenuItem.Icon>
                                        <MenuItem.Header><TextBlock>Copy</TextBlock></MenuItem.Header>
                                    </MenuItem>
                                    <MenuItem Command="{x:Static window:MainWindow.LocateCommand}"
                                              ToolTip="View advanced location information">
                                        <MenuItem.Icon>
                                            <materialDesign:PackIcon Kind="Location"/>
                                        </MenuItem.Icon>
                                        <MenuItem.Header><TextBlock>Locate</TextBlock></MenuItem.Header>
                                    </MenuItem>
                                    <MenuItem Command="{x:Static window:MainWindow.TcpProbeCommand}"
                                              ToolTip="Initiate TCP connection to host">
                                        <MenuItem.Icon>
                                            <materialDesign:PackIcon Kind="SatelliteVariant"/>
                                        </MenuItem.Icon>
                                        <MenuItem.Header><TextBlock>TCP Probe</TextBlock></MenuItem.Header>
                                    </MenuItem>
                                    <Separator/>
                                    <MenuItem Command="{x:Static window:MainWindow.ExportCommand}"
                                              ToolTip="Export all capture results">
                                        <MenuItem.Icon>
                                            <materialDesign:PackIcon Kind="FileExportOutline"/>
                                        </MenuItem.Icon>
                                        <MenuItem.Header><TextBlock>Export</TextBlock></MenuItem.Header>
                                    </MenuItem>
                                    <Separator/>
                                    <MenuItem Command="{x:Static window:MainWindow.RemoveAtCommand}"
                                              ToolTip="Remove selected entry">
                                        <MenuItem.Icon>
                                            <materialDesign:PackIcon Kind="Clear"/>
                                        </MenuItem.Icon>
                                        <MenuItem.Header><TextBlock>Remove selected</TextBlock></MenuItem.Header>
                                    </MenuItem>
                                    <MenuItem Command="{x:Static window:MainWindow.ClearAllCommand}"
                                              ToolTip="Clear all entries">
                                        <MenuItem.Icon>
                                            <materialDesign:PackIcon Kind="RubbishBinOutline"/>
                                        </MenuItem.Icon>
                                        <MenuItem.Header><TextBlock>Clear all</TextBlock></MenuItem.Header>
                                    </MenuItem>
                                    <Separator/>
                                    <MenuItem x:Name="AnalyseMenuItem"
                                              Command="{x:Static window:MainWindow.AnalyseCommand}"
                                              ToolTip="Analyse the selected entry">
                                        <MenuItem.Icon>
                                            <materialDesign:PackIcon Kind="Search"/>
                                        </MenuItem.Icon>
                                        <MenuItem.Header><TextBlock>Analyse</TextBlock></MenuItem.Header>
                                    </MenuItem>
                                    <MenuItem x:Name="AddToLabelsMenuItem"
                                              Command="{x:Static window:MainWindow.LabelCommand}"
                                              ToolTip="Add this entry to the labels list">
                                        <MenuItem.Icon>
                                            <materialDesign:PackIcon Kind="LabelVariantOutline"/>
                                        </MenuItem.Icon>
                                        <MenuItem.Header><TextBlock>Add to labels</TextBlock></MenuItem.Header>
                                    </MenuItem>
                                </ContextMenu>
                            </DataGrid.ContextMenu>
                        </DataGrid>

                        <!-- Panel vacío -->
                        <StackPanel HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    IsHitTestVisible="False">
                            <TextBlock Text="◎" FontSize="52"
                                       Foreground="{DynamicResource BorderNormalBrush}"
                                       HorizontalAlignment="Center"
                                       Margin="0,0,0,14"/>
                            <TextBlock Text="Sin paquetes capturados"
                                       FontFamily="{DynamicResource UiFont}"
                                       FontSize="14"
                                       Foreground="{DynamicResource TextTertiaryBrush}"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Text="Selecciona una interfaz y presiona Capturar"
                                       FontFamily="{DynamicResource UiFont}"
                                       FontSize="11"
                                       Foreground="{DynamicResource TextTertiaryBrush}"
                                       HorizontalAlignment="Center"
                                       Margin="0,5,0,0"/>
                        </StackPanel>

                        <!-- Imagen de fondo (si se configura) -->
                        <Image x:Name="BackgroundImage"
                               HorizontalAlignment="Stretch"
                               VerticalAlignment="Stretch"
                               Stretch="UniformToFill"
                               IsHitTestVisible="False"
                               Panel.ZIndex="-1"/>
                    </Grid>

                    <!-- ══ PANEL LATERAL (detail view) ══ -->
                    <Grid x:Name="SideViewCanvas"
                          Grid.Column="3"
                          Background="{DynamicResource BgSurfaceBrush}"
                          ClipToBounds="True">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="64"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0"
                                Background="{DynamicResource BgSurface2Brush}"
                                BorderBrush="{DynamicResource BorderSubtleBrush}"
                                BorderThickness="0,0,0,0.5"
                                WindowChrome.IsHitTestVisibleInChrome="True">
                            <Grid Margin="16,0">
                                <TextBlock x:Name="SideViewTitle"
                                           HorizontalAlignment="Left"
                                           VerticalAlignment="Center"
                                           Style="{DynamicResource CyberSniffTitle}"
                                           Text="Detail"
                                           WindowChrome.IsHitTestVisibleInChrome="True"/>
                                <Button x:Name="CloseSideView"
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Center"
                                        Width="32" Height="32"
                                        Style="{DynamicResource BtnGhost}"
                                        Command="{x:Static window:MainWindow.HideSideView}"
                                        Cursor="Hand"
                                        ToolTip="Close this panel"
                                        WindowChrome.IsHitTestVisibleInChrome="True">
                                    <materialDesign:PackIcon x:Name="PackIcon1"
                                                             Kind="WindowClose"
                                                             Width="14" Height="14"
                                                             Foreground="{DynamicResource TextSecondaryBrush}"/>
                                </Button>
                            </Grid>
                        </Border>

                        <Frame x:Name="SideViewFrame"
                               Grid.Row="1"
                               HorizontalAlignment="Stretch"
                               VerticalAlignment="Stretch"
                               NavigationUIVisibility="Hidden"/>
                    </Grid>
                </Grid>

                <!-- ══════════════════════════════════════════════════════
                     BARRA DE ESTADO INFERIOR
                     ══════════════════════════════════════════════════════ -->
                <Border Grid.Row="4"
                        Background="{DynamicResource BgSurfaceBrush}"
                        CornerRadius="0,0,12,12"
                        BorderBrush="{DynamicResource BorderSubtleBrush}"
                        BorderThickness="0,0.5,0,0">
                    <Grid Margin="14,0">
                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Center">
                            <TextBlock Style="{DynamicResource LabelCaps}" VerticalAlignment="Center">
                                <Run Text="INTERFAZ: "/>
                            </TextBlock>
                            <TextBlock x:Name="TxtStatusIface"
                                       Text="—"
                                       FontFamily="{DynamicResource MonoFont}"
                                       FontSize="9"
                                       Foreground="{DynamicResource AccentGreenBrush}"
                                       VerticalAlignment="Center"
                                       Margin="0,0,14,0"/>
                            <TextBlock Style="{DynamicResource LabelCaps}" VerticalAlignment="Center">
                                <Run Text="SESIÓN: "/>
                            </TextBlock>
                            <TextBlock x:Name="TxtSessionTime"
                                       Text="00:00:00"
                                       FontFamily="{DynamicResource MonoFont}"
                                       FontSize="9"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock HorizontalAlignment="Right"
                                   VerticalAlignment="Center"
                                   FontFamily="{DynamicResource MonoFont}"
                                   FontSize="9"
                                   Foreground="{DynamicResource TextTertiaryBrush}"
                                   Text="CyberSniff v3.2  ·  .NET 6  ·  WPF  ·  SharpPcap"/>
                    </Grid>
                </Border>

                <!-- Notificación flotante -->
                <Grid x:Name="NotificationGrid"
                      Grid.Row="1" Grid.RowSpan="2"
                      Width="380" Height="72"
                      Margin="0,10,14,0"
                      HorizontalAlignment="Right"
                      VerticalAlignment="Top"
                      Background="{DynamicResource BgSurface3Brush}"
                      Opacity="0"
                      Visibility="Hidden"
                      Panel.ZIndex="100">
                    <Grid.Effect>
                        <DropShadowEffect BlurRadius="20" ShadowDepth="0"
                                          Color="#CC000000" Opacity="0.6"/>
                    </Grid.Effect>
                    <Border CornerRadius="10"
                            BorderBrush="{DynamicResource BorderNormalBrush}"
                            BorderThickness="0.5">
                        <Grid Margin="14,0">
                            <materialDesign:PackIcon x:Name="NotificationIcon"
                                                     Width="24" Height="24"
                                                     Margin="0,0,0,0"
                                                     HorizontalAlignment="Left"
                                                     VerticalAlignment="Center"
                                                     Kind="InfoOutline"
                                                     Foreground="{DynamicResource AccentCyanBrush}"/>
                            <StackPanel Margin="36,0,36,0" VerticalAlignment="Center">
                                <TextBlock x:Name="NotificationTitle"
                                           Text="Notice"
                                           FontFamily="{DynamicResource UiFont}"
                                           FontSize="12" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                                <TextBlock x:Name="NotificationDescription"
                                           Text="Description"
                                           FontFamily="{DynamicResource UiFont}"
                                           FontSize="10"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                            <Button HorizontalAlignment="Right"
                                    VerticalAlignment="Center"
                                    Width="28" Height="28"
                                    Style="{DynamicResource BtnGhost}"
                                    Command="{x:Static window:MainWindow.HideNotification}"
                                    Cursor="Hand"
                                    WindowChrome.IsHitTestVisibleInChrome="True">
                                <materialDesign:PackIcon Kind="WindowClose" Width="12" Height="12"
                                                         Foreground="{DynamicResource TextSecondaryBrush}"/>
                            </Button>
                        </Grid>
                    </Border>
                </Grid>

            </Grid>
        </materialDesign:DialogHost>
    </Border>
</Window>